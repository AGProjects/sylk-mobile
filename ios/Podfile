  pod 'glog', :podspec => '../node_modules/react-native/third-party-podspecs/glog.podspec'
  #pod 'Folly', :podspec => '../node_modules/react-native/third-party-podspecs/Folly.podspec'
  pod 'RCT-Folly', :podspec => "../node_modules/react-native/third-party-podspecs/RCT-Folly.podspec"
  #pod 'Folly', :podspec => '../node_modules/react-native/third-party-podspecs/Folly.podspec'
  target 'sylkTests' do
    inherit! :search_paths
    # Pods for testing


  end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      # Apple Silicon Macs run the iOS Simulator as arm64. Excluding
      # arm64 here forces an x86_64-only build that LLDB can't attach
      # to natively (you'd see "specified architecture 'arm64-*-*' is
      # not compatible with 'x86_64-apple-ios*-simulator'"). Leave the
      # setting unset so pods build for whatever arch the host needs;
      # all currently-pinned pods ship arm64 simulator slices.
      config.build_settings.delete('EXCLUDED_ARCHS[sdk=iphonesimulator*]')
      # C++20 is required by the iOS 26 SDK headers (Apple clang 17+ has
      # deprecated several C++17-only constructs that RCT-Folly's
      # config.h still references). Stays compatible with RN 0.73's
      # RCT-Folly podspec.
      config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++20'
      config.build_settings['CLANG_CXX_LIBRARY'] = 'libc++'
      # Bumped from iOS 14 to iOS 15.1 for Xcode 26 / iOS 26 SDK
      # compliance (App Store Connect rejects builds linking to the
      # iOS 26 SDK with deployment targets older than what the SDK
      # supports). 15.1 is the practical floor for RN 0.73 + Xcode 26.
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.1'

      # RCT-Folly defines required for C++20 compilation under the
      # iOS 26 SDK. FOLLY_MOBILE / FOLLY_USE_LIBCPP keep its config.h
      # off the unavailable POSIX paths; FOLLY_HAVE_CLOCK_GETTIME stops
      # it falling back to mach_absolute_time which Apple now warns on.
      existing_defs = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] || ['$(inherited)']
      existing_defs = [existing_defs] unless existing_defs.is_a?(Array)
      folly_defs = [
        'FOLLY_NO_CONFIG=1',
        'FOLLY_MOBILE=1',
        'FOLLY_USE_LIBCPP=1',
        'FOLLY_HAVE_CLOCK_GETTIME=1',
      ]
      folly_defs.each do |d|
        existing_defs << d unless existing_defs.include?(d)
      end
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = existing_defs

      # Apple clang 17 (Xcode 26) removed -Wno-shorten-64-to-32 from
      # its accepted flag set; some pods (Flipper, FBLazyVector) still
      # ship it in OTHER_CFLAGS and the build now errors out. Strip it.
      ['OTHER_CFLAGS', 'OTHER_CPLUSPLUSFLAGS'].each do |flag_key|
        flags = config.build_settings[flag_key]
        next unless flags
        flags = flags.is_a?(Array) ? flags : flags.split(' ')
        flags = flags.reject { |f| f == '-Wno-shorten-64-to-32' }
        config.build_settings[flag_key] = flags
      end

    end

    if target.name == 'Flipper'
      file_path = 'Pods/Flipper/xplat/Flipper/FlipperTransportTypes.h'
      contents = File.read(file_path)
      unless contents.include?('#include <functional>')
        File.chmod(0755, file_path)
        File.open(file_path, 'w') do |file|
          file.puts('#include <functional>')
          file.puts(contents)
        end
      end
    end
  end

  # ---- RCT-Folly / Flipper-Folly CacheLocality fix --------------------------
  #
  # Xcode 26's libc++ no longer marks std::atomic<T> as trivial (its internal
  # layout changed), so std::is_trivial<GlobalState>::value is now false.
  # Folly's static_assert is overly strict — what it actually needs is for
  # the static-local GlobalState to have a trivial destructor (so safe
  # zero-initialization on first use is sound). Relax the assert to test
  # that property explicitly. Idempotent: bails if the relaxed form is
  # already in place. Runs every time `pod install` regenerates Pods/.
  Dir.glob('Pods/**/folly/concurrency/CacheLocality.{h,cpp}').each do |path|
    src = File.read(path)
    next if src.include?('std::is_trivially_destructible<GlobalState>::value')
    next unless src.include?('std::is_trivial<GlobalState>::value')
    patched = src.gsub(
      /static_assert\s*\(\s*std::is_trivial<GlobalState>::value\s*\|\|\s*kCpplibVer\s*,\s*"not trivial"\s*\)\s*;/m,
      'static_assert(' \
        'is_constexpr_default_constructible_v<GlobalState> && ' \
        'std::is_trivially_destructible<GlobalState>::value, ' \
        '"unsuitable for global state");'
    )
    if patched == src
      Pod::UI.warn "Folly CacheLocality patch: pattern not matched in #{path} — please verify by hand."
    else
      File.write(path, patched)
      Pod::UI.puts "Folly CacheLocality patch: relaxed static_assert in #{path}"
    end
  end
  # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
  react_native_post_install(
    installer,
    config[:reactNativePath],
    :mac_catalyst_enabled => false
   )
    ## Fix for XCode 12.5
    #find_and_replace("../node_modules/react-native/React/CxxBridge/RCTCxxBridge.mm",
    #"_initializeModules:(NSArray<id<RCTBridgeModule>> *)modules", "_initializeModules:(NSArray<Class> *)modules")
    #find_and_replace("../node_modules/react-native/ReactCommon/turbomodule/core/platform/ios/RCTTurboModuleManager.mm",
    #    "RCTBridgeModuleNameForClass(module))", "RCTBridgeModuleNameForClass(Class(module)))")
end
end

