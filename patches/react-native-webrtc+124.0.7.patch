+// ---- Obj-C surface --------------------------------------------------------
+
+// Informal-protocol category declarations for the framework's Obj-C
+// `setFrameEncryptor:` / `setFrameDecryptor:` selectors. These selectors
+// exist on RTCRtpSender / RTCRtpReceiver in the prebuilt
+// JitsiWebRTC.framework — proven by the strings dump showing
+// `-[RTCRtpSender ... setFrameEncryptor:]` and the type encoding
+// `v24@0:8{scoped_refptr<webrtc::FrameEncryptorInterface>=^{...}}16`
+// (i.e. a method that takes a scoped_refptr by value). They're just not
+// publicly declared in the framework headers.
+//
+// Calling the Obj-C entrypoint instead of the C++
+// `native->SetFrameEncryptor()` lets the framework's wrapper run any
+// thread-dispatch / state-bookkeeping it needs (capturing the encryptor
+// in an Obj-C ivar, marshalling onto the signaling thread, etc.). The
+// C++ direct path appears to register our object but never wire it into
+// the encode/decode pipeline on this prebuilt framework.
+//
+// The selectors take a struct {scoped_refptr<...> = pointer} which on
+// arm64 is passed in one register, exactly like a raw pointer. So the
+// type encoding lines up with what the compiler emits for these calls.
+@interface NSObject (SylkE2EE_FrameEncryption)
+- (void)setFrameEncryptor:(rtc::scoped_refptr<webrtc::FrameEncryptorInterface>)encryptor;
+- (void)setFrameDecryptor:(rtc::scoped_refptr<webrtc::FrameDecryptorInterface>)decryptor;
+@end
+
+// Keep strong references to every installed encryptor/decryptor so their
+// refcount doesn't drop to zero the instant the install function returns.
+//
+// On iOS M124, the prebuilt JitsiWebRTC.framework's
+// RtpSenderInterface::SetFrameEncryptor / RtpReceiverInterface::SetFrameDecryptor
+// take a scoped_refptr by value but apparently don't keep the strong ref
+// internally — the dtor of our MediaFrameEncryptor fires within
+// microseconds of the install completing, leaving the sender/receiver
+// without any encryptor. Result: outgoing frames go on the wire
+// unencrypted (or with garbage padding) and incoming encrypted frames
+// fall through to the decoder as ciphertext → garbled audio + frozen
+// video, but ONLY after the ZRTP handshake completes (the first ~3s of
+// plaintext flow fine because no encryption is even attempted yet).
+//
+// Holding the scoped_refptr in this static map keeps the refcount > 0
+// for the lifetime of the call. Entries are cleared when the same
+// sender/receiver gets a new encryptor/decryptor installed (replacing
+// the old one), or stay alive through the call's natural teardown.
+static NSLock *g_sylkRefLock = nil;
+static std::map<webrtc::RtpSenderInterface*,
+                rtc::scoped_refptr<webrtc::FrameEncryptorInterface>> *
+    g_senderEncryptors = nullptr;
+static std::map<webrtc::RtpReceiverInterface*,
+                rtc::scoped_refptr<webrtc::FrameDecryptorInterface>> *
+    g_receiverDecryptors = nullptr;
+
+static void EnsureSylkRefMaps() {
+    static dispatch_once_t once;
+    dispatch_once(&once, ^{
+        g_sylkRefLock = [[NSLock alloc] init];
+        g_senderEncryptors = new std::map<webrtc::RtpSenderInterface*,
+            rtc::scoped_refptr<webrtc::FrameEncryptorInterface>>();
+        g_receiverDecryptors = new std::map<webrtc::RtpReceiverInterface*,
+            rtc::scoped_refptr<webrtc::FrameDecryptorInterface>>();
+    });
+}
+
+static void RetainEncryptor(webrtc::RtpSenderInterface* native,
+                            rtc::scoped_refptr<webrtc::FrameEncryptorInterface> enc) {
+    EnsureSylkRefMaps();
+    [g_sylkRefLock lock];
+    (*g_senderEncryptors)[native] = enc;
+    const size_t total = g_senderEncryptors->size();
+    [g_sylkRefLock unlock];
+    SZLOG(@"RetainEncryptor: stored ref for sender=%p (total live encryptors=%zu)",
+          native, total);
+}
+
+static void RetainDecryptor(webrtc::RtpReceiverInterface* native,
+                            rtc::scoped_refptr<webrtc::FrameDecryptorInterface> dec) {
+    EnsureSylkRefMaps();
+    [g_sylkRefLock lock];
+    (*g_receiverDecryptors)[native] = dec;
+    const size_t total = g_receiverDecryptors->size();
+    [g_sylkRefLock unlock];
+    SZLOG(@"RetainDecryptor: stored ref for receiver=%p (total live decryptors=%zu)",
+          native, total);
+}
+
+@implementation SylkZRTPBridge
+
++ (BOOL)installNoopEncryptorOnSender:(id<RTC_OBJC_TYPE(RTCRtpSender)>)sender {
+    if (!sender) return NO;
+    webrtc::RtpSenderInterface* native = GetNativeRtpSender(sender);
+    if (!native) {
+        SZLOG(@"installNoopEncryptorOnSender: native pointer not found");
+        return NO;
+    }
+    auto* enc = new sylkzrtp::NoopFrameEncryptor();
+    enc->AddRef();   // intentional leak — see Phase 3 install below
+    rtc::scoped_refptr<webrtc::FrameEncryptorInterface> ref(enc);
+    native->SetFrameEncryptor(ref);
+    RetainEncryptor(native, ref);   // belt-and-suspenders
+    SZLOG(@"installed noop encryptor on sender %p (native=%p)", sender, native);
+    return YES;
+}
+
++ (BOOL)installNoopDecryptorOnReceiver:(id<RTC_OBJC_TYPE(RTCRtpReceiver)>)receiver {
+    if (!receiver) return NO;
+    webrtc::RtpReceiverInterface* native = GetNativeRtpReceiver(receiver);
+    if (!native) {
+        SZLOG(@"installNoopDecryptorOnReceiver: native pointer not found");
+        return NO;
+    }
+    auto* dec = new sylkzrtp::NoopFrameDecryptor();
+    dec->AddRef();   // intentional leak — see Phase 3 install below
+    rtc::scoped_refptr<webrtc::FrameDecryptorInterface> ref(dec);
+    native->SetFrameDecryptor(ref);
+    RetainDecryptor(native, ref);   // belt-and-suspenders
+    SZLOG(@"installed noop decryptor on receiver %p (native=%p)", receiver, native);
+    return YES;
+}
+
++ (BOOL)installMediaEncryptorOnSender:(id<RTC_OBJC_TYPE(RTCRtpSender)>)sender
+                                  key:(NSData *)key
+                                 salt:(NSData *)salt
+                                keyId:(uint8_t)keyId
+                          videoPrefix:(uint8_t)videoPrefix {
+    if (!sender) return NO;
+    if (!key || key.length != sylkzrtp::kKeyLen) {
+        SZLOG(@"installMediaEncryptorOnSender: bad key length %lu",
+              (unsigned long)(key ? key.length : 0));
+        return NO;
+    }
+    if (!salt || salt.length != sylkzrtp::kSaltLen) {
+        SZLOG(@"installMediaEncryptorOnSender: bad salt length %lu",
+              (unsigned long)(salt ? salt.length : 0));
+        return NO;
+    }
+    webrtc::RtpSenderInterface* native = GetNativeRtpSender(sender);
+    if (!native) {
+        SZLOG(@"installMediaEncryptorOnSender: native pointer not found");
+        return NO;
+    }
+    auto* enc = new sylkzrtp::MediaFrameEncryptor(
+        (const uint8_t*)key.bytes,
+        (const uint8_t*)salt.bytes,
+        keyId, videoPrefix);
+    // Intentional leak (see decryptor side). Belt-and-suspenders.
+    enc->AddRef();
+    rtc::scoped_refptr<webrtc::FrameEncryptorInterface> ref(enc);
+
+    // Try the Obj-C wrapper's setFrameEncryptor: selector first. The
+    // wrapper does additional bookkeeping (thread dispatch + Obj-C ivar
+    // retention) that the bare C++ call skips. If the wrapper's selector
+    // doesn't exist for some reason, fall back to the direct C++ call.
+    SEL sel = @selector(setFrameEncryptor:);
+    if ([(NSObject*)sender respondsToSelector:sel]) {
+        [(NSObject*)sender setFrameEncryptor:ref];
+        SZLOG(@"installed AES-GCM encryptor via Obj-C setFrameEncryptor: on %p"
+              @" (native=%p) keyId=%u videoPrefix=%u",
+              sender, native, (unsigned)keyId, (unsigned)videoPrefix);
+    } else {
+        native->SetFrameEncryptor(ref);
+        SZLOG(@"installed AES-GCM encryptor via C++ SetFrameEncryptor on sender=%p"
+              @" (native=%p) keyId=%u videoPrefix=%u (Obj-C selector not found)",
+              sender, native, (unsigned)keyId, (unsigned)videoPrefix);
+    }
+    RetainEncryptor(native, ref);   // belt-and-suspenders
+    return YES;
+}
+
++ (BOOL)installMediaDecryptorOnReceiver:(id<RTC_OBJC_TYPE(RTCRtpReceiver)>)receiver
+                                    key:(NSData *)key
+                                   salt:(NSData *)salt
+                                  keyId:(uint8_t)keyId
+                            videoPrefix:(uint8_t)videoPrefix {
+    if (!receiver) return NO;
+    if (!key || key.length != sylkzrtp::kKeyLen) {
+        SZLOG(@"installMediaDecryptorOnReceiver: bad key length %lu",
+              (unsigned long)(key ? key.length : 0));
+        return NO;
+    }
+    if (!salt || salt.length != sylkzrtp::kSaltLen) {
+        SZLOG(@"installMediaDecryptorOnReceiver: bad salt length %lu",
+              (unsigned long)(salt ? salt.length : 0));
+        return NO;
+    }
+    webrtc::RtpReceiverInterface* native = GetNativeRtpReceiver(receiver);
+    if (!native) {
+        SZLOG(@"installMediaDecryptorOnReceiver: native pointer not found");
+        return NO;
+    }
+    auto* dec = new sylkzrtp::MediaFrameDecryptor(
+        (const uint8_t*)key.bytes,
+        (const uint8_t*)salt.bytes,
+        keyId, videoPrefix);
+    // Intentional leak. Belt-and-suspenders.
+    dec->AddRef();
+    rtc::scoped_refptr<webrtc::FrameDecryptorInterface> ref(dec);
+
+    // Same pattern as encryptor — Obj-C path first, C++ fallback.
+    SEL sel = @selector(setFrameDecryptor:);
+    if ([(NSObject*)receiver respondsToSelector:sel]) {
+        [(NSObject*)receiver setFrameDecryptor:ref];
+        SZLOG(@"installed AES-GCM decryptor via Obj-C setFrameDecryptor: on %p"
+              @" (native=%p) keyId=%u videoPrefix=%u",
+              receiver, native, (unsigned)keyId, (unsigned)videoPrefix);
+    } else {
+        native->SetFrameDecryptor(ref);
+        SZLOG(@"installed AES-GCM decryptor via C++ SetFrameDecryptor on receiver=%p"
+              @" (native=%p) keyId=%u videoPrefix=%u (Obj-C selector not found)",
+              receiver, native, (unsigned)keyId, (unsigned)videoPrefix);
+    }
+    RetainDecryptor(native, ref);   // belt-and-suspenders
+    return YES;
+}
+
++ (NSString *)sylkE2EEBuild {
+    return @SYLK_E2EE_BUILD;
+}
+
+@end
