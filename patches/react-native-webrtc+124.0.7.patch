+// WebRTCModule+SylkZRTP.mm
+//
+// React Native bridge methods (RCT_EXPORT_METHOD) for the iOS noop
+// FrameEncryptor / FrameDecryptor install. The JS side calls these via
+// senderInstallNoopEncryption / receiverInstallNoopDecryption — same names
+// as on Android. .mm so we can include sylk_webrtc_compat.h and call the
+// C++ helper indirectly through SylkZRTPBridge (which is Obj-C++ itself).
+
+#import "WebRTCModule+SylkZRTP.h"
+#import "WebRTCModule+RTCPeerConnection.h"
+
+#import <WebRTC/RTCPeerConnection.h>
+#import <WebRTC/RTCRtpSender.h>
+#import <WebRTC/RTCRtpReceiver.h>
+
+#import "SylkZRTPBridge.h"
+
+// Decode a hex string to NSData. Returns nil on parse error.
+static NSData *SylkDecodeHex(NSString *hex) {
+    if (!hex) return nil;
+    NSUInteger len = hex.length;
+    if ((len & 1) != 0) return nil;
+    NSMutableData *out = [NSMutableData dataWithLength:len / 2];
+    uint8_t *bytes = (uint8_t *)out.mutableBytes;
+    const char *cstr = hex.UTF8String;
+    for (NSUInteger i = 0; i < len; i += 2) {
+        char hi = cstr[i];
+        char lo = cstr[i + 1];
+        int hiv = (hi >= '0' && hi <= '9') ? hi - '0'
+                : (hi >= 'a' && hi <= 'f') ? hi - 'a' + 10
+                : (hi >= 'A' && hi <= 'F') ? hi - 'A' + 10 : -1;
+        int lov = (lo >= '0' && lo <= '9') ? lo - '0'
+                : (lo >= 'a' && lo <= 'f') ? lo - 'a' + 10
+                : (lo >= 'A' && lo <= 'F') ? lo - 'A' + 10 : -1;
+        if (hiv < 0 || lov < 0) return nil;
+        bytes[i / 2] = (uint8_t)((hiv << 4) | lov);
+    }
+    return out;
+}
+
+@implementation WebRTCModule (SylkZRTP)
+
+// Returns the SYLK_E2EE_BUILD string compiled into this binary so the JS
+// side can verify the loaded native code matches its expected build.
+// Mismatch => stale build / patch-package didn't run / wrong .framework.
+RCT_EXPORT_METHOD(getSylkE2EEBuild
+                  : (RCTPromiseResolveBlock)resolve
+                  rejecter
+                  : (RCTPromiseRejectBlock)reject) {
+    NSString *build = [SylkZRTPBridge sylkE2EEBuild];
+    resolve(build ?: @"unknown");
+}
+
+RCT_EXPORT_METHOD(senderInstallNoopEncryption
+                  : (nonnull NSNumber *)pcId senderId
+                  : (nonnull NSString *)senderId resolver
+                  : (RCTPromiseResolveBlock)resolve rejecter
+                  : (RCTPromiseRejectBlock)reject) {
+    RTCPeerConnection *peerConnection = self.peerConnections[pcId];
+    if (!peerConnection) {
+        reject(@"E_NO_PC", @"Peer Connection not initialized", nil);
+        return;
+    }
+
+    id<RTC_OBJC_TYPE(RTCRtpSender)> targetSender = nil;
+    for (id<RTC_OBJC_TYPE(RTCRtpSender)> s in peerConnection.senders) {
+        if ([s.senderId isEqualToString:senderId]) {
+            targetSender = s;
+            break;
+        }
+    }
+    if (!targetSender) {
+        reject(@"E_NO_SENDER", [NSString stringWithFormat:@"Sender not found: %@", senderId], nil);
+        return;
+    }
+
+    BOOL ok = [SylkZRTPBridge installNoopEncryptorOnSender:targetSender];
+    if (!ok) {
+        reject(@"E_INSTALL_FAILED",
+               @"Could not unwrap native RTCRtpSender — see [SylkZRTP] logs for ivar list", nil);
+        return;
+    }
+    resolve(nil);
+}
+
+RCT_EXPORT_METHOD(receiverInstallNoopDecryption
+                  : (nonnull NSNumber *)pcId receiverId
+                  : (nonnull NSString *)receiverId resolver
+                  : (RCTPromiseResolveBlock)resolve rejecter
+                  : (RCTPromiseRejectBlock)reject) {
+    RTCPeerConnection *peerConnection = self.peerConnections[pcId];
+    if (!peerConnection) {
+        reject(@"E_NO_PC", @"Peer Connection not initialized", nil);
+        return;
+    }
+
+    id<RTC_OBJC_TYPE(RTCRtpReceiver)> targetReceiver = nil;
+    for (id<RTC_OBJC_TYPE(RTCRtpReceiver)> r in peerConnection.receivers) {
+        if ([r.receiverId isEqualToString:receiverId]) {
+            targetReceiver = r;
+            break;
+        }
+    }
+    if (!targetReceiver) {
+        reject(@"E_NO_RECEIVER",
+               [NSString stringWithFormat:@"Receiver not found: %@", receiverId], nil);
+        return;
+    }
+
+    BOOL ok = [SylkZRTPBridge installNoopDecryptorOnReceiver:targetReceiver];
+    if (!ok) {
+        reject(@"E_INSTALL_FAILED",
+               @"Could not unwrap native RTCRtpReceiver — see [SylkZRTP] logs for ivar list", nil);
+        return;
+    }
+    resolve(nil);
+}
+
+// ---- Phase 3: keyed AES-128-GCM install --------------------------------
+
+RCT_EXPORT_METHOD(senderInstallMediaEncryption
+                  : (nonnull NSNumber *)pcId senderId
+                  : (nonnull NSString *)senderId keyHex
+                  : (nonnull NSString *)keyHex saltHex
+                  : (nonnull NSString *)saltHex keyId
+                  : (nonnull NSNumber *)keyId videoPrefix
+                  : (nonnull NSNumber *)videoPrefix resolver
+                  : (RCTPromiseResolveBlock)resolve rejecter
+                  : (RCTPromiseRejectBlock)reject) {
+    RTCPeerConnection *peerConnection = self.peerConnections[pcId];
+    if (!peerConnection) {
+        reject(@"E_NO_PC", @"Peer Connection not initialized", nil);
+        return;
+    }
+    NSData *key  = SylkDecodeHex(keyHex);
+    NSData *salt = SylkDecodeHex(saltHex);
+    if (!key || key.length != 16) {
+        reject(@"E_BAD_KEY",  @"Invalid key (need 16 bytes hex)", nil);
+        return;
+    }
+    if (!salt || salt.length != 8) {
+        reject(@"E_BAD_SALT", @"Invalid salt (need 8 bytes hex)", nil);
+        return;
+    }
+
+    id<RTC_OBJC_TYPE(RTCRtpSender)> targetSender = nil;
+    for (id<RTC_OBJC_TYPE(RTCRtpSender)> s in peerConnection.senders) {
+        if ([s.senderId isEqualToString:senderId]) {
+            targetSender = s;
+            break;
+        }
+    }
+    if (!targetSender) {
+        reject(@"E_NO_SENDER", [NSString stringWithFormat:@"Sender not found: %@", senderId], nil);
+        return;
+    }
+
+    BOOL ok = [SylkZRTPBridge installMediaEncryptorOnSender:targetSender
+                                                        key:key
+                                                       salt:salt
+                                                      keyId:(uint8_t)keyId.intValue
+                                                videoPrefix:(uint8_t)videoPrefix.intValue];
+    if (!ok) {
+        reject(@"E_INSTALL_FAILED",
+               @"Could not install AES-GCM encryptor — see [SylkZRTP] logs", nil);
+        return;
+    }
+    resolve(nil);
+}
+
+RCT_EXPORT_METHOD(receiverInstallMediaDecryption
+                  : (nonnull NSNumber *)pcId receiverId
+                  : (nonnull NSString *)receiverId keyHex
+                  : (nonnull NSString *)keyHex saltHex
+                  : (nonnull NSString *)saltHex keyId
+                  : (nonnull NSNumber *)keyId videoPrefix
+                  : (nonnull NSNumber *)videoPrefix resolver
+                  : (RCTPromiseResolveBlock)resolve rejecter
+                  : (RCTPromiseRejectBlock)reject) {
+    RTCPeerConnection *peerConnection = self.peerConnections[pcId];
+    if (!peerConnection) {
+        reject(@"E_NO_PC", @"Peer Connection not initialized", nil);
+        return;
+    }
+    NSData *key  = SylkDecodeHex(keyHex);
+    NSData *salt = SylkDecodeHex(saltHex);
+    if (!key || key.length != 16) {
+        reject(@"E_BAD_KEY",  @"Invalid key (need 16 bytes hex)", nil);
+        return;
+    }
+    if (!salt || salt.length != 8) {
+        reject(@"E_BAD_SALT", @"Invalid salt (need 8 bytes hex)", nil);
+        return;
+    }
+
+    id<RTC_OBJC_TYPE(RTCRtpReceiver)> targetReceiver = nil;
+    for (id<RTC_OBJC_TYPE(RTCRtpReceiver)> r in peerConnection.receivers) {
+        if ([r.receiverId isEqualToString:receiverId]) {
+            targetReceiver = r;
+            break;
+        }
+    }
+    if (!targetReceiver) {
+        reject(@"E_NO_RECEIVER",
+               [NSString stringWithFormat:@"Receiver not found: %@", receiverId], nil);
+        return;
+    }
+
+    BOOL ok = [SylkZRTPBridge installMediaDecryptorOnReceiver:targetReceiver
+                                                          key:key
+                                                         salt:salt
+                                                        keyId:(uint8_t)keyId.intValue
+                                                  videoPrefix:(uint8_t)videoPrefix.intValue];
+    if (!ok) {
+        reject(@"E_INSTALL_FAILED",
+               @"Could not install AES-GCM decryptor — see [SylkZRTP] logs", nil);
+        return;
+    }
+    resolve(nil);
+}
+
+@end
