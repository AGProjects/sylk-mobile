+// ---- Phase 3: keyed AES-128-GCM encryptor / decryptor --------------------
+
+class MediaFrameEncryptor : public webrtc::FrameEncryptorInterface {
+ public:
+    MediaFrameEncryptor(const uint8_t* key, const uint8_t* salt,
+                        uint8_t keyId, uint8_t videoPrefix)
+        : ref_count_(0), keyId_(keyId & 0x0F),
+          videoPrefix_(videoPrefix), counter_(0) {
+        std::memcpy(key_,  key,  kKeyLen);
+        std::memcpy(salt_, salt, kSaltLen);
+        SZLOG(@"MediaFrameEncryptor ctor %p keyId=%u videoPrefix=%u",
+              this, (unsigned)keyId_, (unsigned)videoPrefix_);
+    }
+
+    // Codec-dependent number of bytes left plaintext at start of each
+    // video frame (VP8=1, VP9=3, H264=2, AV1=1). JS computes the value
+    // from the negotiated codec and passes it via the constructor.
+    size_t UnencryptedPrefixForMediaType(cricket::MediaType mt) const {
+        return mt == cricket::MEDIA_TYPE_VIDEO ? (size_t)videoPrefix_ : 0;
+    }
+
+    int Encrypt(cricket::MediaType media_type,
+                uint32_t /*ssrc*/,
+                rtc::ArrayView<const uint8_t> /*additional_data*/,
+                rtc::ArrayView<const uint8_t> frame,
+                rtc::ArrayView<uint8_t> encrypted_frame,
+                size_t* bytes_written) override {
+        // One-shot proof-of-life log on the FIRST call to Encrypt — needed
+        // to confirm libwebrtc on this iOS framework is actually invoking
+        // our FrameEncryptor in the outgoing media path. If this never
+        // logs, SetFrameEncryptor accepted our object but the framework
+        // doesn't run frames through it.
+        static std::atomic<bool> g_encryptLogged{false};
+        bool expected = false;
+        if (g_encryptLogged.compare_exchange_strong(expected, true)) {
+            SZLOG(@"[SylkZRTP][encrypt] FIRST CALL — Encrypt() invoked, media_type=%d frameSize=%zu prefix=%zu",
+                  (int)media_type, frame.size(),
+                  UnencryptedPrefixForMediaType(media_type));
+        }
+
+        const size_t prefix = UnencryptedPrefixForMediaType(media_type);
+        if (frame.size() < prefix) return -1;
+        const size_t needed = frame.size() + kFrameOverhead;
+        if (encrypted_frame.size() < needed) return -1;
+
+        const uint32_t counter = counter_.fetch_add(1, std::memory_order_relaxed) + 1;
+        const uint8_t header = MakeHeader(/*version=*/1, keyId_);
+
+        uint8_t iv[kIvLen];
+        BuildIV(salt_, counter, iv);
+
+        uint8_t aad[kHeaderLen + kCounterLen];
+        BuildAAD(header, counter, aad);
+
+        uint8_t* out = encrypted_frame.data();
+        // 1. Plaintext prefix (codec descriptor bytes) copied as-is.
+        if (prefix > 0) {
+            std::memcpy(out, frame.data(), prefix);
+        }
+        // 2. Our 5-byte header (version|keyId + 32-bit BE counter).
+        out[prefix + 0] = header;
+        out[prefix + 1] = aad[1];
+        out[prefix + 2] = aad[2];
+        out[prefix + 3] = aad[3];
+        out[prefix + 4] = aad[4];
+        // 3. Encrypt only the bytes AFTER the prefix.
+        if (!AesGcmEncrypt(key_, iv, aad, sizeof(aad),
+                           frame.data() + prefix, frame.size() - prefix,
+                           out + prefix + kHeaderLen + kCounterLen)) {
+            return -1;
+        }
+        *bytes_written = needed;
+        return 0;
+    }
+
+    size_t GetMaxCiphertextByteSize(cricket::MediaType /*media_type*/,
+                                    size_t frame_size) override {
+        return frame_size + kFrameOverhead;
+    }
+
+    void AddRef() const override {
+        ref_count_.fetch_add(1, std::memory_order_relaxed);
+    }
+    webrtc::RefCountReleaseStatus Release() const override {
+        const int prev = ref_count_.fetch_sub(1, std::memory_order_acq_rel);
+        if (prev == 1) {
+            delete this;
+            return webrtc::RefCountReleaseStatus::kDroppedLastRef;
+        }
+        return webrtc::RefCountReleaseStatus::kOtherRefsRemained;
+    }
+
+ protected:
+    ~MediaFrameEncryptor() override {
+        SZLOG(@"MediaFrameEncryptor dtor %p", this);
+    }
+
+ private:
+    mutable std::atomic<int> ref_count_;
+    uint8_t key_[kKeyLen];
+    uint8_t salt_[kSaltLen];
+    uint8_t keyId_;
+    uint8_t videoPrefix_;   // bytes left plaintext at start of each video frame
+    std::atomic<uint32_t> counter_;
+};
+
+class MediaFrameDecryptor : public webrtc::FrameDecryptorInterface {
+ public:
+    MediaFrameDecryptor(const uint8_t* key, const uint8_t* salt,
+                        uint8_t keyId, uint8_t videoPrefix)
+        : ref_count_(0), keyId_(keyId & 0x0F), videoPrefix_(videoPrefix) {
+        std::memcpy(key_,  key,  kKeyLen);
+        std::memcpy(salt_, salt, kSaltLen);
+        SZLOG(@"MediaFrameDecryptor ctor %p keyId=%u videoPrefix=%u",
+              this, (unsigned)keyId_, (unsigned)videoPrefix_);
+    }
+
+    // Must match MediaFrameEncryptor's prefix or every frame fails the
+    // tag check and falls through to permissive passthrough.
+    size_t UnencryptedPrefixForMediaType(cricket::MediaType mt) const {
+        return mt == cricket::MEDIA_TYPE_VIDEO ? (size_t)videoPrefix_ : 0;
+    }
+
+    // Permissive decrypt — same policy as the Android side.
+    // If the frame doesn't look encrypted (wrong header / too short / tag
+    // mismatch), pass it through unchanged. Lets us decrypt the peer's
+    // encrypted frames while the peer's sender_enc isn't yet installed.
+    Result Decrypt(cricket::MediaType media_type,
+                   const std::vector<uint32_t>& /*csrcs*/,
+                   rtc::ArrayView<const uint8_t> /*additional_data*/,
+                   rtc::ArrayView<const uint8_t> encrypted_frame,
+                   rtc::ArrayView<uint8_t> frame) override {
+        const size_t prefix = UnencryptedPrefixForMediaType(media_type);
+
+        // One-line diagnostic counters, sampled at exponential decay so
+        // we don't spam the log (~50/sec/track when video is flowing).
+        // Updated by passthrough() via the lambda capture.
+        static std::atomic<uint64_t> g_total{0};
+        static std::atomic<uint64_t> g_short{0};
+        static std::atomic<uint64_t> g_hdrMismatch{0};
+        static std::atomic<uint64_t> g_smallOut{0};
+        static std::atomic<uint64_t> g_tagFail{0};
+        static std::atomic<uint64_t> g_ok{0};
+
+        auto bumpAndMaybeLog = [&]() {
+            const uint64_t n = g_total.fetch_add(1, std::memory_order_relaxed) + 1;
+            // Log on n=1, 10, 100, 1000, 10000, ...
+            uint64_t k = n; bool logIt = (n == 1);
+            while (k > 0 && (k % 10) == 0) { logIt = true; k /= 10; if (k == 1) break; if ((k % 10) != 0) { logIt = false; break; } }
+            if (n <= 10 || (n % 100) == 0) {
+                SZLOG(@"[SylkZRTP][decrypt-stats] total=%llu short=%llu hdrBad=%llu smallOut=%llu tagFail=%llu ok=%llu",
+                      (unsigned long long)n,
+                      (unsigned long long)g_short.load(),
+                      (unsigned long long)g_hdrMismatch.load(),
+                      (unsigned long long)g_smallOut.load(),
+                      (unsigned long long)g_tagFail.load(),
+                      (unsigned long long)g_ok.load());
+            }
+        };
+
+        auto passthrough = [&]() -> Result {
+            if (frame.size() < encrypted_frame.size()) {
+                return Result(Status::kFailedToDecrypt, 0);
+            }
+            std::memcpy(frame.data(), encrypted_frame.data(), encrypted_frame.size());
+            return Result(Status::kOk, encrypted_frame.size());
+        };
+
+        if (encrypted_frame.size() < prefix + kFrameOverhead) {
+            g_short.fetch_add(1, std::memory_order_relaxed);
+            bumpAndMaybeLog();
+            return passthrough();
+        }
+        const uint8_t* in = encrypted_frame.data();
+        const uint8_t header = in[prefix];
+        const uint8_t version = (header >> 4) & 0x0F;
+        const uint8_t keyId   =  header       & 0x0F;
+        if (version != 1 || keyId != keyId_) {
+            const uint64_t bad = g_hdrMismatch.fetch_add(1, std::memory_order_relaxed) + 1;
+            if (bad <= 5 || (bad % 200) == 0) {
+                SZLOG(@"[SylkZRTP][decrypt] header mismatch: got version=%u keyId=%u (want version=1 keyId=%u) frameLen=%zu prefix=%zu",
+                      (unsigned)version, (unsigned)keyId, (unsigned)keyId_,
+                      encrypted_frame.size(), prefix);
+            }
+            bumpAndMaybeLog();
+            return passthrough();
+        }
+        const uint32_t counter =
+            ((uint32_t)in[prefix + 1] << 24) | ((uint32_t)in[prefix + 2] << 16) |
+            ((uint32_t)in[prefix + 3] <<  8) |  (uint32_t)in[prefix + 4];
+
+        const size_t ctTagLen     = encrypted_frame.size() - prefix - (kHeaderLen + kCounterLen);
+        const size_t plaintextLen = ctTagLen - kTagLen;
+        const size_t outLen       = prefix + plaintextLen;
+        if (frame.size() < outLen) {
+            g_smallOut.fetch_add(1, std::memory_order_relaxed);
+            bumpAndMaybeLog();
+            return passthrough();
+        }
+
+        uint8_t iv[kIvLen];
+        BuildIV(salt_, counter, iv);
+
+        uint8_t aad[kHeaderLen + kCounterLen];
+        BuildAAD(header, counter, aad);
+
+        // Copy the plaintext prefix bytes back, decrypt the rest into
+        // frame[prefix..].
+        if (prefix > 0) {
+            std::memcpy(frame.data(), in, prefix);
+        }
+        if (!AesGcmDecrypt(key_, iv, aad, sizeof(aad),
+                           in + prefix + kHeaderLen + kCounterLen, ctTagLen,
+                           frame.data() + prefix)) {
+            const uint64_t bad = g_tagFail.fetch_add(1, std::memory_order_relaxed) + 1;
+            if (bad <= 5 || (bad % 200) == 0) {
+                SZLOG(@"[SylkZRTP][decrypt] GCM tag check FAILED: counter=%u keyId=%u prefix=%zu frameLen=%zu (this means the encryptor's bytes don't match the AAD/IV we computed — usually a key/salt mismatch or wire-format skew)",
+                      (unsigned)counter, (unsigned)keyId, prefix, encrypted_frame.size());
+                // Dump the first 32 bytes of the encrypted frame for hex inspection.
+                NSMutableString *hex = [NSMutableString stringWithCapacity:96];
+                size_t dumpLen = encrypted_frame.size() > 32 ? 32 : encrypted_frame.size();
+                for (size_t i = 0; i < dumpLen; i++) {
+                    [hex appendFormat:@"%02x ", encrypted_frame.data()[i]];
+                }
+                SZLOG(@"[SylkZRTP][decrypt]   first %zu bytes: %@", dumpLen, hex);
+            }
+            bumpAndMaybeLog();
+            return passthrough();
+        }
+        g_ok.fetch_add(1, std::memory_order_relaxed);
+        bumpAndMaybeLog();
+        return Result(Status::kOk, outLen);
+    }
+
+    // Output buffer must hold either plaintext (encrypted_size - 21)
+    // or a passthrough copy (= encrypted_size).
+    size_t GetMaxPlaintextByteSize(cricket::MediaType /*media_type*/,
+                                   size_t encrypted_frame_size) override {
+        return encrypted_frame_size;
+    }
+
+    void AddRef() const override {
+        ref_count_.fetch_add(1, std::memory_order_relaxed);
+    }
+    webrtc::RefCountReleaseStatus Release() const override {
+        const int prev = ref_count_.fetch_sub(1, std::memory_order_acq_rel);
+        if (prev == 1) {
+            delete this;
+            return webrtc::RefCountReleaseStatus::kDroppedLastRef;
+        }
+        return webrtc::RefCountReleaseStatus::kOtherRefsRemained;
+    }
+
+ protected:
+    ~MediaFrameDecryptor() override {
+        SZLOG(@"MediaFrameDecryptor dtor %p", this);
+    }
+
+ private:
+    mutable std::atomic<int> ref_count_;
+    uint8_t key_[kKeyLen];
+    uint8_t salt_[kSaltLen];
+    uint8_t keyId_;
+    uint8_t videoPrefix_;   // bytes left plaintext at start of each video frame
+};
+
+}  // namespace sylkzrtp
