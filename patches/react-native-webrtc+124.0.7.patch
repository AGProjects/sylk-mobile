index 0000000..4aa61c7
--- /dev/null
+++ b/node_modules/react-native-webrtc/android/src/main/java/com/oney/WebRTCModule/SylkE2EE.java
@@ -0,0 +1,181 @@
+// SylkE2EE.java — Java side of the Sylk ZRTP FrameEncryptor / FrameDecryptor
+// JNI bridge. Phase 3: real AES-128-GCM. The C++ side calls back into the
+// aesGcmEncrypt / aesGcmDecrypt static helpers below for each frame —
+// keeps the crypto in the platform's vetted javax.crypto and avoids
+// vendoring a C crypto library into the native build.
+//
+// Two inner classes (MediaEncryptor / MediaDecryptor) implement
+// org.webrtc.FrameEncryptor / org.webrtc.FrameDecryptor. Each holds a long
+// pointing at the matching C++ object, returned via getNativeFrameEncryptor
+// / getNativeFrameDecryptor. When libwebrtc's RtpSender.setFrameEncryptor()
+// or RtpReceiver.setFrameDecryptor() is called with one of these holders,
+// libwebrtc reads the long and treats it as a webrtc::FrameEncryptorInterface*
+// (resp. webrtc::FrameDecryptorInterface*).
+
+package com.oney.WebRTCModule;
+
+import android.util.Log;
+
+import javax.crypto.Cipher;
+import javax.crypto.spec.GCMParameterSpec;
+import javax.crypto.spec.SecretKeySpec;
+
+import org.webrtc.FrameDecryptor;
+import org.webrtc.FrameEncryptor;
+
+public final class SylkE2EE {
+    private static final String TAG = "SylkZRTP";
+    private static final String GCM_TRANSFORMATION = "AES/GCM/NoPadding";
+    private static final int GCM_TAG_BITS = 128;
+
+    static {
+        try {
+            System.loadLibrary("sylk_e2ee");
+            // Tiny touch of the JNI to surface UnsatisfiedLinkError early
+            // if the .so didn't ship correctly. No log on the happy path.
+            nativeHello();
+        } catch (UnsatisfiedLinkError e) {
+            Log.e(TAG, "Failed to load sylk_e2ee native lib", e);
+        } catch (Throwable t) {
+            Log.e(TAG, "sylk_e2ee init threw", t);
+        }
+    }
+
+    /** Force class initialization (and therefore native lib loading). */
+    public static void touch() {}
+
+    private SylkE2EE() {}
+
+    // ---- JNI surface (package-private; called from inner classes) ---------
+
+    static native int nativeHello();
+    static native String nativeGetBuild();
+    static native long nativeCreateNoopEncryptor();
+    static native long nativeCreateNoopDecryptor();
+    static native long nativeCreateMediaEncryptor(byte[] key, byte[] salt, int keyId, int videoPrefix);
+    static native long nativeCreateMediaDecryptor(byte[] key, byte[] salt, int keyId, int videoPrefix);
+    static native void nativeReleaseEncryptor(long ptr);
+    static native void nativeReleaseDecryptor(long ptr);
+
+    /** Returns the SYLK_E2EE_BUILD string baked into the loaded .so so the
+     *  caller can verify it matches the version the JS side expects. */
+    public static String getBuild() {
+        try {
+            return nativeGetBuild();
+        } catch (Throwable t) {
+            Log.e(TAG, "nativeGetBuild failed", t);
+            return "unknown";
+        }
+    }
+
+    // ---- AES-GCM helpers (called from C++ via JNI for every frame) --------
+    //
+    // Both return the same byte layout javax.crypto.Cipher uses for GCM:
+    // ciphertext concatenated with the 16-byte authentication tag. On
+    // decrypt failure (wrong key/IV/tag, or truncated input) we return
+    // null instead of throwing, so the native side can propagate a clean
+    // FrameDecryptor::Status::kFailedToDecrypt back to libwebrtc.
+
+    public static byte[] aesGcmEncrypt(byte[] key, byte[] iv, byte[] aad, byte[] plaintext) {
+        try {
+            final Cipher cipher = Cipher.getInstance(GCM_TRANSFORMATION);
+            final SecretKeySpec keySpec = new SecretKeySpec(key, "AES");
+            final GCMParameterSpec gcmSpec = new GCMParameterSpec(GCM_TAG_BITS, iv);
+            cipher.init(Cipher.ENCRYPT_MODE, keySpec, gcmSpec);
+            if (aad != null && aad.length > 0) {
+                cipher.updateAAD(aad);
+            }
+            return cipher.doFinal(plaintext != null ? plaintext : new byte[0]);
+        } catch (Throwable t) {
+            Log.e(TAG, "aesGcmEncrypt failed", t);
+            return null;
+        }
+    }
+
+    public static byte[] aesGcmDecrypt(byte[] key, byte[] iv, byte[] aad, byte[] ciphertextWithTag) {
+        try {
+            final Cipher cipher = Cipher.getInstance(GCM_TRANSFORMATION);
+            final SecretKeySpec keySpec = new SecretKeySpec(key, "AES");
+            final GCMParameterSpec gcmSpec = new GCMParameterSpec(GCM_TAG_BITS, iv);
+            cipher.init(Cipher.DECRYPT_MODE, keySpec, gcmSpec);
+            if (aad != null && aad.length > 0) {
+                cipher.updateAAD(aad);
+            }
+            return cipher.doFinal(ciphertextWithTag);
+        } catch (Throwable t) {
+            // Common case: AEADBadTagException — wrong key/tag mismatch.
+            // Don't log noisily; return null and let the C++ side report
+            // kFailedToDecrypt.
+            return null;
+        }
+    }
+
+    // ---- FrameEncryptor holder --------------------------------------------
+
+    /**
+     * Wraps a C++ webrtc::FrameEncryptorInterface* allocated in JNI. Pass an
+     * instance of this to RtpSender.setFrameEncryptor() to install. Caller
+     * must call release() once libwebrtc no longer holds a reference.
+     */
+    public static final class MediaEncryptor implements FrameEncryptor {
+        private long nativePtr;
+
+        /** Phase 2: noop passthrough — keeps frames unchanged. */
+        public MediaEncryptor() {
+            this.nativePtr = nativeCreateNoopEncryptor();
+        }
+
+        /**
+         * Phase 3: AES-128-GCM with the given key (16 bytes) + salt (8 bytes).
+         * videoPrefix is the number of bytes left UN-encrypted at the start of
+         * each video frame (codec-dependent: VP8=1, VP9=3, H264=2, AV1=1, audio=0).
+         */
+        public MediaEncryptor(byte[] key, byte[] salt, int keyId, int videoPrefix) {
+            this.nativePtr = nativeCreateMediaEncryptor(key, salt, keyId, videoPrefix);
+        }
+
+        @Override
+        public long getNativeFrameEncryptor() {
+            return nativePtr;
+        }
+
+        public void release() {
+            if (nativePtr != 0) {
+                nativeReleaseEncryptor(nativePtr);
+                nativePtr = 0;
+            }
+        }
+    }
+
+    // ---- FrameDecryptor holder --------------------------------------------
+
+    public static final class MediaDecryptor implements FrameDecryptor {
+        private long nativePtr;
+
+        /** Phase 2: noop passthrough. */
+        public MediaDecryptor() {
+            this.nativePtr = nativeCreateNoopDecryptor();
+        }
+
+        /**
+         * Phase 3: AES-128-GCM. videoPrefix must match what the peer's
+         * encryptor used; mismatch makes the decrypt's permissive
+         * passthrough kick in for every frame.
+         */
+        public MediaDecryptor(byte[] key, byte[] salt, int keyId, int videoPrefix) {
+            this.nativePtr = nativeCreateMediaDecryptor(key, salt, keyId, videoPrefix);
+        }
+
+        @Override
+        public long getNativeFrameDecryptor() {
+            return nativePtr;
+        }
+
+        public void release() {
+            if (nativePtr != 0) {
+                nativeReleaseDecryptor(nativePtr);
+                nativePtr = 0;
+            }
+        }
+    }
+}
