index 0000000..e080862
--- /dev/null
+++ b/node_modules/react-native-webrtc/android/src/main/cpp/sylk_webrtc_compat.h
@@ -0,0 +1,122 @@
+// sylk_webrtc_compat.h
+//
+// Minimal slice of the WebRTC M124 public C++ API needed to implement
+// FrameEncryptorInterface and FrameDecryptorInterface. We deliberately do
+// NOT include the upstream api/crypto/frame_encryptor_interface.h because
+// it transitively pulls in abseil (string_view, type_traits) which we do
+// not want to vendor.
+//
+// Each declaration here mirrors the upstream M124 source layout exactly
+// (verified against branch-heads/6261 in webrtc.googlesource.com/src), so
+// our derived classes share the same vtable layout as the binary produced
+// by org.jitsi:webrtc:124.+ at runtime. If the upstream headers change in
+// a future milestone, regenerate this file from the new headers — see the
+// comments next to each class.
+
+#ifndef SYLK_WEBRTC_COMPAT_H_
+#define SYLK_WEBRTC_COMPAT_H_
+
+#include <cstddef>
+#include <cstdint>
+#include <vector>
+
+// ---- cricket::MediaType (api/media_types.h) -------------------------------
+
+namespace cricket {
+
+enum MediaType {
+    MEDIA_TYPE_AUDIO,
+    MEDIA_TYPE_VIDEO,
+    MEDIA_TYPE_DATA,
+    MEDIA_TYPE_UNSUPPORTED,
+};
+
+}  // namespace cricket
+
+// ---- webrtc::RefCountInterface (api/ref_count.h) --------------------------
+
+namespace webrtc {
+
+enum class RefCountReleaseStatus { kDroppedLastRef, kOtherRefsRemained };
+
+class RefCountInterface {
+ public:
+    virtual void AddRef() const = 0;
+    virtual RefCountReleaseStatus Release() const = 0;
+ protected:
+    virtual ~RefCountInterface() {}
+};
+
+}  // namespace webrtc
+
+// ---- rtc:: aliases (rtc_base/ref_count.h) ---------------------------------
+
+namespace rtc {
+
+using RefCountInterface = ::webrtc::RefCountInterface;
+using RefCountReleaseStatus = ::webrtc::RefCountReleaseStatus;
+
+// ---- rtc::ArrayView (api/array_view.h, variable-size variant) -------------
+// Layout matches the upstream variable-size ArrayView: T* data + size_t size.
+// Only members read by FrameEncryptor/Decryptor implementations are exposed.
+template <typename T>
+class ArrayView final {
+ public:
+    ArrayView() : data_(nullptr), size_(0) {}
+    ArrayView(T* data, size_t size) : data_(data), size_(size) {}
+    T* data() const { return data_; }
+    size_t size() const { return size_; }
+    bool empty() const { return size_ == 0; }
+ private:
+    T* data_;
+    size_t size_;
+};
+
+}  // namespace rtc
+
+// ---- webrtc::FrameEncryptorInterface (api/crypto/frame_encryptor_interface.h)
+// ---- webrtc::FrameDecryptorInterface (api/crypto/frame_decryptor_interface.h)
+
+namespace webrtc {
+
+class FrameEncryptorInterface : public rtc::RefCountInterface {
+ public:
+    ~FrameEncryptorInterface() override {}
+
+    virtual int Encrypt(cricket::MediaType media_type,
+                        uint32_t ssrc,
+                        rtc::ArrayView<const uint8_t> additional_data,
+                        rtc::ArrayView<const uint8_t> frame,
+                        rtc::ArrayView<uint8_t> encrypted_frame,
+                        size_t* bytes_written) = 0;
+
+    virtual size_t GetMaxCiphertextByteSize(cricket::MediaType media_type,
+                                            size_t frame_size) = 0;
+};
+
+class FrameDecryptorInterface : public rtc::RefCountInterface {
+ public:
+    enum class Status { kOk, kRecoverable, kFailedToDecrypt, kUnknown };
+
+    struct Result {
+        Result(Status s, size_t b) : status(s), bytes_written(b) {}
+        bool IsOk() const { return status == Status::kOk; }
+        const Status status;
+        const size_t bytes_written;
+    };
+
+    ~FrameDecryptorInterface() override {}
+
+    virtual Result Decrypt(cricket::MediaType media_type,
+                           const std::vector<uint32_t>& csrcs,
+                           rtc::ArrayView<const uint8_t> additional_data,
+                           rtc::ArrayView<const uint8_t> encrypted_frame,
+                           rtc::ArrayView<uint8_t> frame) = 0;
+
+    virtual size_t GetMaxPlaintextByteSize(cricket::MediaType media_type,
+                                           size_t encrypted_frame_size) = 0;
+};
+
+}  // namespace webrtc
+
+#endif  // SYLK_WEBRTC_COMPAT_H_
