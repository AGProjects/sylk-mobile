index 0000000..dce4e05
--- /dev/null
+++ b/node_modules/react-native-webrtc/ios/RCTWebRTC/sylk_webrtc_compat.h
@@ -0,0 +1,137 @@
+// sylk_webrtc_compat.h  (iOS copy — identical to Android's)
+//
+// Minimal slice of the WebRTC M124 public C++ API needed to implement
+// FrameEncryptorInterface and FrameDecryptorInterface. Mirrors the upstream
+// declarations exactly so our derived classes share the same vtable layout
+// as the JitsiWebRTC.framework binary at runtime.
+
+#ifndef SYLK_WEBRTC_COMPAT_H_
+#define SYLK_WEBRTC_COMPAT_H_
+
+#include <cstddef>
+#include <cstdint>
+#include <vector>
+
+namespace cricket {
+
+enum MediaType {
+    MEDIA_TYPE_AUDIO,
+    MEDIA_TYPE_VIDEO,
+    MEDIA_TYPE_DATA,
+    MEDIA_TYPE_UNSUPPORTED,
+};
+
+}  // namespace cricket
+
+namespace webrtc {
+
+enum class RefCountReleaseStatus { kDroppedLastRef, kOtherRefsRemained };
+
+class RefCountInterface {
+ public:
+    virtual void AddRef() const = 0;
+    virtual RefCountReleaseStatus Release() const = 0;
+ protected:
+    virtual ~RefCountInterface() {}
+};
+
+}  // namespace webrtc
+
+namespace rtc {
+
+using RefCountInterface = ::webrtc::RefCountInterface;
+using RefCountReleaseStatus = ::webrtc::RefCountReleaseStatus;
+
+template <typename T>
+class ArrayView final {
+ public:
+    ArrayView() : data_(nullptr), size_(0) {}
+    ArrayView(T* data, size_t size) : data_(data), size_(size) {}
+    T* data() const { return data_; }
+    size_t size() const { return size_; }
+    bool empty() const { return size_ == 0; }
+ private:
+    T* data_;
+    size_t size_;
+};
+
+// Bare-bones scoped_refptr matching upstream layout (single T* member).
+// We only need it to wrap a raw pointer when calling into WebRTC's
+// SetFrameEncryptor / SetFrameDecryptor; behaviour matches webrtc's:
+// constructor calls AddRef, destructor calls Release.
+template <class T>
+class scoped_refptr {
+ public:
+    scoped_refptr() : ptr_(nullptr) {}
+    explicit scoped_refptr(T* p) : ptr_(p) { if (ptr_) ptr_->AddRef(); }
+    scoped_refptr(const scoped_refptr<T>& r) : ptr_(r.ptr_) { if (ptr_) ptr_->AddRef(); }
+    ~scoped_refptr() { if (ptr_) ptr_->Release(); }
+    T* get() const { return ptr_; }
+    T* operator->() const { return ptr_; }
+ private:
+    T* ptr_;
+};
+
+}  // namespace rtc
+
+namespace webrtc {
+
+class FrameEncryptorInterface : public rtc::RefCountInterface {
+ public:
+    ~FrameEncryptorInterface() override {}
+
+    virtual int Encrypt(cricket::MediaType media_type,
+                        uint32_t ssrc,
+                        rtc::ArrayView<const uint8_t> additional_data,
+                        rtc::ArrayView<const uint8_t> frame,
+                        rtc::ArrayView<uint8_t> encrypted_frame,
+                        size_t* bytes_written) = 0;
+
+    virtual size_t GetMaxCiphertextByteSize(cricket::MediaType media_type,
+                                            size_t frame_size) = 0;
+};
+
+class FrameDecryptorInterface : public rtc::RefCountInterface {
+ public:
+    enum class Status { kOk, kRecoverable, kFailedToDecrypt, kUnknown };
+
+    struct Result {
+        Result(Status s, size_t b) : status(s), bytes_written(b) {}
+        bool IsOk() const { return status == Status::kOk; }
+        const Status status;
+        const size_t bytes_written;
+    };
+
+    ~FrameDecryptorInterface() override {}
+
+    virtual Result Decrypt(cricket::MediaType media_type,
+                           const std::vector<uint32_t>& csrcs,
+                           rtc::ArrayView<const uint8_t> additional_data,
+                           rtc::ArrayView<const uint8_t> encrypted_frame,
+                           rtc::ArrayView<uint8_t> frame) = 0;
+
+    virtual size_t GetMaxPlaintextByteSize(cricket::MediaType media_type,
+                                           size_t encrypted_frame_size) = 0;
+};
+
+// Forward declarations for the WebRTC native interfaces — we only ever
+// hold pointers, never call methods on them directly. SetFrameEncryptor /
+// SetFrameDecryptor is invoked by reading the private `_nativeRtpSender`
+// / `_nativeRtpReceiver` ivar from the Objective-C wrapper and casting.
+class RtpSenderInterface {
+ public:
+    virtual void SetFrameEncryptor(rtc::scoped_refptr<FrameEncryptorInterface> frame_encryptor) = 0;
+ protected:
+    virtual ~RtpSenderInterface() {}
+};
+
+class RtpReceiverInterface {
+ public:
+    virtual void SetFrameDecryptor(rtc::scoped_refptr<FrameDecryptorInterface> frame_decryptor) = 0;
+ protected:
+    virtual ~RtpReceiverInterface() {}
+};
+
+}  // namespace webrtc
+
+#endif  // SYLK_WEBRTC_COMPAT_H_
