+// ---- runtime-ivar unwrap helpers ------------------------------------------
+
+// Find a pointer-sized ivar by trying a list of likely names. On failure
+// dumps the wrapper's ivar list to NSLog so the caller can update the list.
+static void* GetPointerIvarBytes(NSObject* obj, const char* const* candidates,
+                                 size_t numCandidates) {
+    Class cls = [obj class];
+    for (size_t i = 0; i < numCandidates; i++) {
+        Ivar iv = class_getInstanceVariable(cls, candidates[i]);
+        if (iv) {
+            ptrdiff_t offset = ivar_getOffset(iv);
+            return (char*)(__bridge void*)obj + offset;
+        }
+    }
+    // Diagnostic dump — only fires when none of the candidate names matched.
+    unsigned int count = 0;
+    Ivar* list = class_copyIvarList(cls, &count);
+    SZLOG(@"could not find a candidate ivar on %s; full ivar list:",
+          class_getName(cls));
+    for (unsigned int i = 0; i < count; i++) {
+        SZLOG(@"  ivar %u: name=%s type=%s",
+              i, ivar_getName(list[i]), ivar_getTypeEncoding(list[i]));
+    }
+    free(list);
+    return nullptr;
+}
+
+static webrtc::RtpSenderInterface* GetNativeRtpSender(id<RTC_OBJC_TYPE(RTCRtpSender)> objcSender) {
+    static const char* candidates[] = {
+        "_nativeRtpSender", "nativeRtpSender",
+        "_nativeRtpSenderRefPtr", "nativeRtpSenderRefPtr",
+        "_nativeSender", "nativeSender",
+    };
+    void* bytes = GetPointerIvarBytes((NSObject*)objcSender, candidates,
+                                      sizeof(candidates) / sizeof(candidates[0]));
+    if (!bytes) return nullptr;
+    // The ivar is a scoped_refptr<RtpSenderInterface> = exactly one pointer.
+    webrtc::RtpSenderInterface** native = (webrtc::RtpSenderInterface**)bytes;
+    return *native;
+}
+
+static webrtc::RtpReceiverInterface* GetNativeRtpReceiver(id<RTC_OBJC_TYPE(RTCRtpReceiver)> objcReceiver) {
+    static const char* candidates[] = {
+        "_nativeRtpReceiver", "nativeRtpReceiver",
+        "_nativeRtpReceiverRefPtr", "nativeRtpReceiverRefPtr",
+        "_nativeReceiver", "nativeReceiver",
+    };
+    void* bytes = GetPointerIvarBytes((NSObject*)objcReceiver, candidates,
+                                      sizeof(candidates) / sizeof(candidates[0]));
+    if (!bytes) return nullptr;
+    webrtc::RtpReceiverInterface** native = (webrtc::RtpReceiverInterface**)bytes;
+    return *native;
+}
