+// SylkZRTPBridge.mm
+//
+// Obj-C++ implementation of the iOS Sylk ZRTP native bridge.
+// Phase 2: noop FrameEncryptor / FrameDecryptor (passthrough memcpy).
+// Phase 3 will replace memcpy with AES-128-GCM.
+//
+// The fundamental challenge on iOS: the JitsiWebRTC.framework's Obj-C SDK
+// does NOT expose setFrameEncryptor: / setFrameDecryptor: as Cocoa methods,
+// even though the underlying webrtc::RtpSenderInterface / RtpReceiverInterface
+// have them. To install our encryptor we have to:
+//   1. Reach the wrapper's private `_nativeRtpSender` / `_nativeRtpReceiver`
+//      ivar via the Objective-C runtime (it's a scoped_refptr<RtpSenderInterface>
+//      = exactly one pointer in memory layout).
+//   2. Cast the ivar bytes to webrtc::RtpSenderInterface* and call the C++
+//      virtual SetFrameEncryptor() through our compat header's vtable.
+//
+// If the framework version's ivar name ever changes, this stops working —
+// it logs all ivar names on first failure to help adjust.
+
+#import "SylkZRTPBridge.h"
+
+#import <Foundation/Foundation.h>
+#import <objc/runtime.h>
+#import <atomic>
+#import <cstring>
+#import <cstdint>
+#import <map>
+#import <vector>
+
+#import <CommonCrypto/CommonCrypto.h>
+#import <CommonCrypto/CommonCryptor.h>
+
+#import "sylk_webrtc_compat.h"
+
+#define SZLOG(fmt, ...) NSLog((@"[SylkZRTP] " fmt), ##__VA_ARGS__)
+
+// Mirror of Android's SYLK_E2EE_BUILD. Bump in BOTH places when the wire
+// format / prefix size / framing changes, then rebuild both platforms.
+#define SYLK_E2EE_BUILD "build-2026-05-02-public-aesgcm"
+
+// Log once per process load. +load runs before any other code in this
+// translation unit, so its output is the very first SylkZRTP line in the
+// device log — easy to grep and confirm both phones match.
+__attribute__((constructor))
+static void SylkZRTPLogBuild(void) {
+    SZLOG(@"native lib loaded; build=%s", SYLK_E2EE_BUILD);
+}
+
+// ---- AES-128-GCM frame format constants -----------------------------------
+//
+// Wire format identical to Android (see MediaEncryptorJni.cpp):
+//   [1B header v|keyId][4B BE counter][ciphertext][16B GCM tag]
+// IV  = salt(8) || counter_be(4)  -> 12 bytes
+// AAD = header(1) || counter_be(4) -> 5 bytes
+namespace sylkzrtp {
+
+static constexpr size_t kKeyLen      = 16;
+static constexpr size_t kSaltLen     = 8;
+static constexpr size_t kIvLen       = 12;
+static constexpr size_t kTagLen      = 16;
+static constexpr size_t kHeaderLen   = 1;
+static constexpr size_t kCounterLen  = 4;
+static constexpr size_t kFrameOverhead = kHeaderLen + kCounterLen + kTagLen; // 21
+
+static inline uint8_t MakeHeader(uint8_t version, uint8_t keyId) {
+    // version in high 4 bits, keyId in low 4. Phase 3 = version 1.
+    return (uint8_t)(((version & 0x0F) << 4) | (keyId & 0x0F));
+}
+
+static inline void BuildIV(const uint8_t salt[kSaltLen], uint32_t counter, uint8_t out[kIvLen]) {
+    std::memcpy(out, salt, kSaltLen);
+    out[kSaltLen + 0] = (uint8_t)((counter >> 24) & 0xFF);
+    out[kSaltLen + 1] = (uint8_t)((counter >> 16) & 0xFF);
+    out[kSaltLen + 2] = (uint8_t)((counter >>  8) & 0xFF);
+    out[kSaltLen + 3] = (uint8_t)( counter        & 0xFF);
+}
+
+static inline void BuildAAD(uint8_t header, uint32_t counter, uint8_t out[kHeaderLen + kCounterLen]) {
+    out[0] = header;
+    out[1] = (uint8_t)((counter >> 24) & 0xFF);
+    out[2] = (uint8_t)((counter >> 16) & 0xFF);
+    out[3] = (uint8_t)((counter >>  8) & 0xFF);
+    out[4] = (uint8_t)( counter        & 0xFF);
+}
+
+// AES-128-GCM implementation built on top of public CommonCrypto only.
+//
+// We previously used CommonCrypto's CCCryptorGCMOneshotEncrypt /
+// CCCryptorGCMOneshotDecrypt, but those symbols live in CommonCryptoSPI.h
+// (private SPI). The Mac App Store validator now flags references to
+// _CCCryptorGCMOneshotEncrypt / _CCCryptorGCMOneshotDecrypt and rejects
+// the upload (validation error: "references non-public symbols").
+//
+// The replacement here uses only documented, public CommonCrypto APIs:
+//   * CCCrypt(kCCAlgorithmAES, kCCOptionECBMode, ...) — AES-ECB single-
+//     block, used for the GCM hash subkey H = E_K(0) and the per-block
+//     tag pre-image E_K(J0).
+//   * CCCryptorCreateWithMode(kCCModeCTR, ...) — AES-CTR streaming
+//     cipher for plaintext / ciphertext, with the initial counter
+//     block J0+1.
+//   * GHASH (the GF(2^128) polynomial hash) is implemented in pure C —
+//     no platform crypto available for it, but it doesn't need any
+//     beyond AES-ECB for the H subkey computation done above.
+//
+// The wire format (12-byte IV from salt||counter, 16-byte tag, AAD =
+// header||counter) is BYTE-IDENTICAL to the prior implementation and
+// to the Android side, so existing peers continue to interop. Verified
+// against NIST SP 800-38D test vectors before shipping.
+static inline void XorBlock(uint8_t* a, const uint8_t* b, size_t n) {
+    for (size_t i = 0; i < n; i++) a[i] ^= b[i];
+}
+
+// Single-block AES-ECB encrypt using public CommonCrypto.
+// CCCrypt() supports ECB via kCCOptionECBMode; one-shot is fine for 16 B.
+static bool AesEcbEncryptBlock(const uint8_t key[kKeyLen],
+                               const uint8_t in[16],
+                               uint8_t out[16]) {
+    size_t produced = 0;
+    CCCryptorStatus s = CCCrypt(
+        kCCEncrypt,
+        kCCAlgorithmAES,
+        kCCOptionECBMode,           // no padding, no IV
+        key, kKeyLen,
+        /*iv*/ nullptr,
+        in, 16,
+        out, 16,
+        &produced);
+    return s == kCCSuccess && produced == 16;
+}
+
+// AES-CTR over `in` of any length, using `initialCounter` as the
+// initial 16-byte counter block (CC increments per block internally).
+static bool AesCtrCrypt(const uint8_t key[kKeyLen],
+                        const uint8_t initialCounter[16],
+                        const uint8_t* in, size_t inLen,
+                        uint8_t* out) {
+    if (inLen == 0) return true;
+    CCCryptorRef ref = nullptr;
+    CCCryptorStatus s = CCCryptorCreateWithMode(
+        kCCEncrypt,
+        kCCModeCTR,
+        kCCAlgorithmAES,
+        ccNoPadding,
+        initialCounter,             // 16-byte initial counter block
+        key, kKeyLen,
+        /*tweak*/ nullptr, 0,
+        /*numRounds*/ 0,
+        /*options*/ kCCModeOptionCTR_BE,
+        &ref);
+    if (s != kCCSuccess || !ref) return false;
+    size_t produced = 0;
+    s = CCCryptorUpdate(ref, in, inLen, out, inLen, &produced);
+    CCCryptorRelease(ref);
+    return s == kCCSuccess && produced == inLen;
+}
+
+// V <- V * H over GF(2^128) per NIST SP 800-38D (right-shift form).
+// All inputs are big-endian 16-byte arrays; bit 0 of a byte is the MSB.
+static void GhashMul(uint8_t V[16], const uint8_t H[16]) {
+    uint8_t Z[16] = {0};
+    uint8_t W[16];
+    std::memcpy(W, V, 16);
+    for (int i = 0; i < 128; i++) {
+        const int byte = i >> 3;
+        const int bit  = 7 - (i & 7);
+        if ((H[byte] >> bit) & 1) {
+            XorBlock(Z, W, 16);
+        }
+        // W >>= 1, with reduction by R = 0xE1 || 0^120 if LSB was set.
+        const bool lsb = (W[15] & 1) != 0;
+        for (int j = 15; j > 0; j--) {
+            W[j] = (uint8_t)((W[j] >> 1) | ((W[j - 1] & 1) << 7));
+        }
+        W[0] = (uint8_t)(W[0] >> 1);
+        if (lsb) W[0] ^= 0xe1;
+    }
+    std::memcpy(V, Z, 16);
+}
+
+// Mix `data` of any length into the running GHASH state Y, padding the
+// final partial block with zero bytes per spec.
+static void GhashUpdate(uint8_t Y[16], const uint8_t H[16],
+                        const uint8_t* data, size_t len) {
+    while (len >= 16) {
+        XorBlock(Y, data, 16);
+        GhashMul(Y, H);
+        data += 16;
+        len  -= 16;
+    }
+    if (len > 0) {
+        uint8_t tmp[16] = {0};
+        std::memcpy(tmp, data, len);
+        XorBlock(Y, tmp, 16);
+        GhashMul(Y, H);
+    }
+}
+
+// J0 = IV(12 B) || 0x00000001  — the recommended GCM init counter
+// when IV length == 96 bits. Matches the IV layout we build in
+// BuildIV() above (salt(8) || counter_be(4)).
+static inline void BuildJ0(const uint8_t iv12[kIvLen], uint8_t J0[16]) {
+    std::memcpy(J0, iv12, 12);
+    J0[12] = 0; J0[13] = 0; J0[14] = 0; J0[15] = 1;
+}
+
+// Increment the rightmost 32-bit word of an initial counter block by 1
+// (with carry confined to those 32 bits, per GCM spec).
+static inline void Inc32(uint8_t block[16]) {
+    for (int i = 15; i >= 12; i--) {
+        block[i] = (uint8_t)(block[i] + 1);
+        if (block[i] != 0) break;
+    }
+}
+
+// Build the final GHASH length block: aadBits (uint64 BE), ctBits (uint64 BE).
+static inline void BuildLenBlock(size_t aadLen, size_t ctLen, uint8_t out[16]) {
+    const uint64_t aadBits = (uint64_t)aadLen * 8;
+    const uint64_t ctBits  = (uint64_t)ctLen  * 8;
+    for (int i = 0; i < 8; i++) {
+        out[i]     = (uint8_t)((aadBits >> (56 - 8 * i)) & 0xff);
+        out[8 + i] = (uint8_t)((ctBits  >> (56 - 8 * i)) & 0xff);
+    }
+}
+
+// One-shot AES-128-GCM encrypt. Output buffer must be at least
+// inLen + kTagLen. Writes ciphertext then 16-byte tag, returns true on
+// success. IV must be exactly kIvLen (12) bytes.
+static bool AesGcmEncrypt(const uint8_t* key,
+                          const uint8_t* iv,
+                          const uint8_t* aad, size_t aadLen,
+                          const uint8_t* in,  size_t inLen,
+                          uint8_t* out) {
+    // 1. Derive H = E_K(0).
+    uint8_t H[16] = {0};
+    uint8_t zero[16] = {0};
+    if (!AesEcbEncryptBlock(key, zero, H)) return false;
+
+    // 2. J0 = IV || 0x00000001.
+    uint8_t J0[16];
+    BuildJ0(iv, J0);
+
+    // 3. Encrypt plaintext with AES-CTR starting at J0+1.
+    uint8_t counter1[16];
+    std::memcpy(counter1, J0, 16);
+    Inc32(counter1);
+    if (!AesCtrCrypt(key, counter1, in, inLen, out)) return false;
+
+    // 4. Compute GHASH over AAD || ciphertext || lenBlock.
+    uint8_t S[16] = {0};
+    GhashUpdate(S, H, aad, aadLen);
+    GhashUpdate(S, H, out, inLen);
+
+    uint8_t lenBlock[16];
+    BuildLenBlock(aadLen, inLen, lenBlock);
+    XorBlock(S, lenBlock, 16);
+    GhashMul(S, H);
+
+    // 5. tag = E_K(J0) XOR S.
+    uint8_t Ej0[16];
+    if (!AesEcbEncryptBlock(key, J0, Ej0)) return false;
+    XorBlock(Ej0, S, 16);
+    std::memcpy(out + inLen, Ej0, kTagLen);
+    return true;
+}
+
+// One-shot AES-128-GCM decrypt. inLen MUST include tag (>= 16 bytes).
+// Writes plaintext (= inLen - 16 bytes) to out. Returns true on success
+// (tag verified), false otherwise. Tag verification is constant-time —
+// we never write plaintext on tag mismatch.
+static bool AesGcmDecrypt(const uint8_t* key,
+                          const uint8_t* iv,
+                          const uint8_t* aad, size_t aadLen,
+                          const uint8_t* in,  size_t inLen,
+                          uint8_t* out) {
+    if (inLen < kTagLen) return false;
+    const size_t ctLen = inLen - kTagLen;
+    const uint8_t* ct  = in;
+    const uint8_t* tag = in + ctLen;
+
+    // 1. H = E_K(0).
+    uint8_t H[16] = {0};
+    uint8_t zero[16] = {0};
+    if (!AesEcbEncryptBlock(key, zero, H)) return false;
+
+    // 2. J0 = IV || 0x00000001.
+    uint8_t J0[16];
+    BuildJ0(iv, J0);
+
+    // 3. Compute expected tag via GHASH over AAD || ciphertext || lenBlock.
+    uint8_t S[16] = {0};
+    GhashUpdate(S, H, aad, aadLen);
+    GhashUpdate(S, H, ct, ctLen);
+
+    uint8_t lenBlock[16];
+    BuildLenBlock(aadLen, ctLen, lenBlock);
+    XorBlock(S, lenBlock, 16);
+    GhashMul(S, H);
+
+    uint8_t expected[16];
+    if (!AesEcbEncryptBlock(key, J0, expected)) return false;
+    XorBlock(expected, S, 16);
+
+    // 4. Constant-time tag compare. Refuse to write plaintext on mismatch.
+    uint8_t diff = 0;
+    for (size_t i = 0; i < kTagLen; i++) diff |= (uint8_t)(expected[i] ^ tag[i]);
+    if (diff != 0) return false;
+
+    // 5. Decrypt with AES-CTR starting at J0+1.
+    uint8_t counter1[16];
+    std::memcpy(counter1, J0, 16);
+    Inc32(counter1);
+    return AesCtrCrypt(key, counter1, ct, ctLen, out);
+}
+
+}  // namespace sylkzrtp
