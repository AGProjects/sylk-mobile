+/**
+ * DTMF — RFC 4733 telephone-event packets sent in-band on the audio
+ * RTP stream. JS hands us tones (e.g. "1*7"), duration and gap in
+ * milliseconds; libwebrtc's iOS DtmfSender API takes NSTimeInterval
+ * (seconds), so we divide by 1000. Resolves with the boolean libwebrtc
+ * returns from insertDtmf — true if the queue accepted the tones,
+ * false if canInsertDtmf was false or the sender wasn't audio.
+ *
+ * NOTE: rn-webrtc 124.0.7 doesn't ship this method. The sylkrtc
+ * patch's "audioSender.dtmf" path was therefore always undefined;
+ * this fork closes that gap.
+ */
+RCT_EXPORT_METHOD(senderInsertDtmf : (nonnull NSNumber *)objectID senderId : (NSString *)senderId tones : (
+    NSString *)tones duration : (nonnull NSNumber *)durationMs interToneGap : (
+    nonnull NSNumber *)interToneGapMs resolver : (RCTPromiseResolveBlock)resolve rejecter : (RCTPromiseRejectBlock)reject) {
+    RTCPeerConnection *peerConnection = self.peerConnections[objectID];
+    if (peerConnection == nil) {
+        RCTLogWarn(@"PeerConnection %@ not found in senderInsertDtmf()", objectID);
+        resolve(@NO);
+        return;
+    }
+
+    RTCRtpSender *sender = nil;
+    for (RTCRtpTransceiver *t in peerConnection.transceivers) {
+        if ([senderId isEqual:t.sender.senderId]) {
+            sender = t.sender;
+            break;
+        }
+    }
+    if (sender == nil) {
+        RCTLogWarn(@"senderInsertDtmf() sender %@ not found", senderId);
+        resolve(@NO);
+        return;
+    }
+
+    id<RTCDtmfSender> dtmf = sender.dtmfSender;
+    if (dtmf == nil) {
+        RCTLogWarn(@"senderInsertDtmf() DtmfSender unavailable for sender %@", senderId);
+        resolve(@NO);
+        return;
+    }
+    if (!dtmf.canInsertDtmf) {
+        RCTLogWarn(@"senderInsertDtmf() canInsertDtmf is NO");
+        resolve(@NO);
+        return;
+    }
+
+    NSTimeInterval duration = [durationMs doubleValue] / 1000.0;
+    NSTimeInterval gap = [interToneGapMs doubleValue] / 1000.0;
+    BOOL ok = [dtmf insertDtmf:tones duration:duration interToneGap:gap];
+    RCTLogInfo(@"senderInsertDtmf(\"%@\", %.3fs / %.3fs gap) -> %@", tones, duration, gap, ok ? @"YES" : @"NO");
+    resolve(@(ok));
+}
+
+/**
+ * playInbandDtmf — iOS counterpart TODO.
+ *
+ * The Android side ships an inband DTMF mixer (see
+ * android/src/main/java/com/oney/WebRTCModule/DtmfInbandMixer.java)
+ * wired into the JavaAudioDeviceModule via setAudioRecordDataCallback.
