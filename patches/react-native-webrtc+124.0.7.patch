+// SylkZRTPBridge.h
+//
+// Public Obj-C surface for the iOS Sylk ZRTP native bridge. Counterpart of
+// the Android SylkE2EE.java holders. Two helper functions are exposed for
+// the WebRTC RN module categories to call into.
+
+#import <Foundation/Foundation.h>
+#import <WebRTC/RTCRtpSender.h>
+#import <WebRTC/RTCRtpReceiver.h>
+
+NS_ASSUME_NONNULL_BEGIN
+
+@interface SylkZRTPBridge : NSObject
+
+/// Install a noop FrameEncryptor on the given Objective-C RTCRtpSender.
+/// Returns YES on success, NO if the wrapper's private ivar couldn't be
+/// reached (the only failure mode in practice — version-skew with the
+/// JitsiWebRTC framework).
++ (BOOL)installNoopEncryptorOnSender:(id<RTC_OBJC_TYPE(RTCRtpSender)>)sender;
+
+/// Install a noop FrameDecryptor on the given Objective-C RTCRtpReceiver.
++ (BOOL)installNoopDecryptorOnReceiver:(id<RTC_OBJC_TYPE(RTCRtpReceiver)>)receiver;
+
+/// Phase 3: install a keyed AES-128-GCM FrameEncryptor on the given sender.
+/// `key` must be 16 bytes, `salt` must be 8 bytes. `keyId` is the byte placed
+/// in the per-frame header (must match what the peer's decryptor expects).
+/// `videoPrefix` is the codec-determined number of plaintext bytes left at
+/// the start of each video frame (VP8=1, VP9=3, H264=2, AV1=1).
++ (BOOL)installMediaEncryptorOnSender:(id<RTC_OBJC_TYPE(RTCRtpSender)>)sender
+                                  key:(NSData *)key
+                                 salt:(NSData *)salt
+                                keyId:(uint8_t)keyId
+                          videoPrefix:(uint8_t)videoPrefix;
+
+/// Phase 3: install a keyed AES-128-GCM FrameDecryptor on the given receiver.
++ (BOOL)installMediaDecryptorOnReceiver:(id<RTC_OBJC_TYPE(RTCRtpReceiver)>)receiver
+                                    key:(NSData *)key
+                                   salt:(NSData *)salt
+                                  keyId:(uint8_t)keyId
+                            videoPrefix:(uint8_t)videoPrefix;
+
+/// Returns the SYLK_E2EE_BUILD string compiled into this binary. JS reads
+/// this at app boot and compares against its hard-coded expected value to
+/// detect stale .framework / patch-package skew.
++ (NSString *)sylkE2EEBuild;
+
+@end
+
+NS_ASSUME_NONNULL_END
