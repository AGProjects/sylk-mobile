--- /dev/null
+++ b/node_modules/react-native-webrtc/src/RTCDTMFSender.ts
@@ -0,0 +1,101 @@
+import { NativeModules } from 'react-native';
+
+const { WebRTCModule } = NativeModules;
+
+/**
+ * Minimal RTCDTMFSender JS wrapper for the Sylk fork of
+ * react-native-webrtc. Exposes the W3C-shaped API:
+ *
+ *   sender.dtmf.insertDTMF(tones, duration?, interToneGap?)
+ *   sender.dtmf.toneBuffer       // queued tones not yet played
+ *   sender.dtmf.canInsertDTMF    // boolean
+ *
+ * Tone change events from native are NOT plumbed back yet — sylkrtc
+ * has its `_onDtmf` handler commented out, so the only thing we
+ * actually rely on at the moment is `insertDTMF` reaching libwebrtc.
+ * Adding `tonechange` later is a JS-side EventTarget shim plus a
+ * RCTEventEmitter event from native; the bridge plumbing on the
+ * iOS / Android side is left in place where it was easy to add.
+ *
+ * Both platforms accept tones, duration (ms) and interToneGap (ms);
+ * iOS converts to seconds internally because libwebrtc's iOS API
+ * uses NSTimeInterval.
+ */
+export default class RTCDTMFSender {
+    _peerConnectionId: number;
+    _senderId: string;
+    _toneBuffer: string;
+
+    constructor(peerConnectionId: number, senderId: string) {
+        this._peerConnectionId = peerConnectionId;
+        this._senderId = senderId;
+        this._toneBuffer = '';
+    }
+
+    get toneBuffer(): string {
+        return this._toneBuffer;
+    }
+
+    get canInsertDTMF(): boolean {
+        if (!WebRTCModule || typeof WebRTCModule.senderCanInsertDtmf !== 'function') {
+            return false;
+        }
+        try {
+            // Synchronous bridge call — returns a JS boolean. If the
+            // native module isn't built with the DTMF additions, the
+            // method just isn't there and we fall through to `false`.
+            return !!WebRTCModule.senderCanInsertDtmf(this._peerConnectionId, this._senderId);
+        } catch (e) {
+            return false;
+        }
+    }
+
+    /**
+     * Enqueue the tone string for transmission. Native side calls
+     * libwebrtc's DtmfSender.insertDtmf which packetises each digit
+     * as RFC 4733 telephone-event RTP packets in-band on the audio
+     * stream (payload type negotiated in the SDP, typically 101).
+     */
+    insertDTMF(tones: string, duration: number = 100, interToneGap: number = 70): void {
+        if (typeof tones !== 'string') {
+            throw new TypeError('tones must be a string');
+        }
+        this._toneBuffer = tones;
+
+        // eslint-disable-next-line no-console
+        console.log('[DTMF/rn-webrtc] insertDTMF tones=' + tones
+            + ' duration=' + duration + 'ms gap=' + interToneGap + 'ms'
+            + ' senderId=' + this._senderId
+            + ' bridge=' + (WebRTCModule && typeof WebRTCModule.senderInsertDtmf === 'function'
+                ? 'present' : 'MISSING'));
+
+        if (!WebRTCModule || typeof WebRTCModule.senderInsertDtmf !== 'function') {
+            return;
+        }
+
+        WebRTCModule.senderInsertDtmf(
+            this._peerConnectionId,
+            this._senderId,
+            tones,
+            duration,
+            interToneGap,
+        ).then((ok: boolean) => {
+            // eslint-disable-next-line no-console
+            console.log('[DTMF/rn-webrtc] native senderInsertDtmf resolved ok=' + ok);
+        }).catch((e: any) => {
+            // eslint-disable-next-line no-console
+            console.log('[DTMF/rn-webrtc] native senderInsertDtmf rejected: ' + (e && e.message));
+        });
+    }
+
+    // The W3C spec exposes a tonechange event on this sender. We
+    // mimic only the shape consumers need (addEventListener /
+    // removeEventListener); native event delivery isn't wired yet.
+    addEventListener(_type: string, _listener: any): void {
+        // no-op for now; see class comment
+    }
+
+    removeEventListener(_type: string, _listener: any): void {
+        // no-op
+    }
+}
